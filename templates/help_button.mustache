{{!
    @template local_freshdesk/help_button

    Floating Help button injected on every Moodle page. Clicking it opens
    the support modal rendered by templates/modal.mustache.

    Context variables required for this template:
    * label - Visible button label (e.g. "Get Help")
    * arialabel - aria-label for screen readers (e.g. "Open support widget")

    Example context (json):
    {
        "label": "Get Help",
        "arialabel": "Open support widget"
    }
}}
<button id="fd-help-btn" type="button" aria-label="{{arialabel}}">
    <span aria-hidden="true">&#128587;</span> {{label}}
</button>
