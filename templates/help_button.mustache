{{!
    @template local_freshdesk/help_button

    Floating Help button injected on every Moodle page. Renders as either:
      * a <button> that opens the support modal (full widget mode), or
      * an <a> that opens the Freshdesk portal in a new tab (pass-through
        mode for users without local/freshdesk:use).

    Context variables required for this template:
    * label - Visible button label (e.g. "Get Help")
    * arialabel - aria-label for screen readers
    * icon - Optional icon: Unicode character or image URL (default: 🎓)
    * href - Optional URL. When set, render as a link instead of a button.

    Example context (json):
    {
        "label": "Get Help",
        "arialabel": "Open support widget",
        "icon": "🎓"
    }
}}
{{#href}}
<a id="fd-help-btn" href="{{href}}" target="_blank" rel="noopener noreferrer" aria-label="{{arialabel}}">
    <span aria-hidden="true" class="fd-icon" data-icon="{{icon}}"></span> {{label}}
</a>
{{/href}}
{{^href}}
<button id="fd-help-btn" type="button" aria-label="{{arialabel}}">
    <span aria-hidden="true" class="fd-icon" data-icon="{{icon}}"></span> {{label}}
</button>
{{/href}}
